# AI Meeting Notes Manager - Backend Environment Variables
# Copy to .env for local development

# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# Security & CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://ai-meeting-notes-manager.vercel.app

# Database Storage
DATABASE_URL=sqlite:///./meeting_notes.db

# Optional External AI Services (Disabled by default - system uses local rule-based NLP)
# OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
