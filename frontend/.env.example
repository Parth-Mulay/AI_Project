# ============================================================
# AI Meeting Notes Manager — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values.
# All VITE_ prefixed variables are exposed to the browser bundle.
# NEVER place secrets, private API keys, or JWT secrets here.
# ============================================================

# --- App Identity ---
VITE_APP_NAME="AI Meeting Notes Manager"
VITE_APP_VERSION="1.0.0"

# --- Backend API ---
# Set to your deployed FastAPI backend URL (no trailing slash)
VITE_API_URL=http://127.0.0.1:8000/api/v1

# Timeout for API requests in milliseconds (default: 15000)
VITE_API_TIMEOUT_MS=15000

# --- File Upload Limits ---
# Maximum document file size in MB (docx, pdf, txt)
VITE_UPLOAD_LIMIT_DOCS_MB=10

# Maximum audio file size in MB (mp3, wav)
VITE_UPLOAD_LIMIT_AUDIO_MB=100

# --- AI Provider ---
# Which AI backend is active: openai | anthropic | gemini | mock
VITE_AI_PROVIDER=mock

# --- Feature Flags (true | false) ---
VITE_FEATURE_LIVE_CAPTURE=false
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_WORKSPACE=false
